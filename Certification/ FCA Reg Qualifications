            ParagraphStyle("cs", fontName="Helvetica-Bold", fontSize=18, leading=22,
                           textColor=colors.HexColor("#7AB8F5"), alignment=TA_LEFT)),
    ]]
    cover_sum = Table(summary_data, colWidths=[35*mm]*4, hAlign="LEFT")
    cover_sum.setStyle(TableStyle([
        ("VALIGN", (0,0), (-1,-1), "MIDDLE"),
        ("TOPPADDING", (0,0), (-1,-1), 8),
        ("BOTTOMPADDING", (0,0), (-1,-1), 8),
