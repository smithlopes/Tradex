        ("BACKGROUND", (0,0), (-1,-1), colors.HexColor("#0F2035")),
        ("LINEBELOW", (0,0), (-1,0), 2, GOLD),
    ]))
    story.append(cover_sum)
    story.append(Spacer(1, 68*mm))
    story.append(Paragraph(
        f"Prepared: {date.today().strftime('%B %Y')}     ·     {total} roles assessed     ·     "
        "For professional reference only — not legal advice     ·     "
        "Verify current requirements at handbook.fca.org.uk",
