def p(text, sty="body_sm"):
    return Paragraph(text, S(sty))

def badge_p(text, style="red"):
    cm = {"red":(RED_BADGE,RED_BG),"amber":(AMBER_BADGE,AMBER_BG),"green":(GREEN_BADGE,GREEN_BG),
          "blue":(BLUE_BADGE,BLUE_BG),"purple":(PURPLE_BADGE,PURPLE_BG)}
    fc, bg = cm.get(style, cm["blue"])
    return Paragraph(
        f'<font size="6"><b>{text}</b></font>',
        ParagraphStyle("badge", fontName="Helvetica-Bold", fontSize=6, leading=9,
                       backColor=bg, borderPad=2, textColor=fc))

def status_cell(status, detail):
    """Returns a list of flowables for the compliance status column."""
    cfg = {
        "yes":       ("✔  QUALIFIED", S("status_yes")),
        "no":        ("✘  NOT COVERED", S("status_no")),
        "partial":   ("◑  PARTIAL", S("status_part")),
        "discretion":("~  DISCRETION", S("status_disc")),
    }
    label, sty = cfg[status]
    return [
        Paragraph(label, sty),
        Spacer(1, 2),
        Paragraph(detail, S("note_sm")),
    ]

# ── Page callback ────────────────────────────────────────────────────────────
class DocCanvas:
    def __call__(self, canv, doc):
        canv.saveState()
        w, h = A4
        if doc.page == 1:
            canv.setFillColor(NAVY);  canv.rect(0, 0, w, h, fill=1, stroke=0)
            canv.setFillColor(GOLD);  canv.rect(0, h-8*mm, w, 8*mm, fill=1, stroke=0)
            canv.setFillColor(MID_NAVY); canv.rect(0, 0, w, 28*mm, fill=1, stroke=0)
        else:
            canv.setStrokeColor(NAVY); canv.setLineWidth(0.5)
            canv.line(L_MARGIN, h-13*mm, w-R_MARGIN, h-13*mm)
            canv.setFont("Helvetica", 7); canv.setFillColor(MID_GREY)
            canv.drawString(L_MARGIN, h-10*mm, "FCA REGULATORY QUALIFICATION REQUIREMENTS — IMC L4 + CFA LEVEL I COMPLIANCE STATUS")
            canv.drawRightString(w-R_MARGIN, h-10*mm, f"Page {doc.page}")
            canv.setStrokeColor(RULE_GREY); canv.setLineWidth(0.3)
            canv.line(L_MARGIN, 14*mm, w-R_MARGIN, 14*mm)
            canv.setFont("Helvetica", 6.5); canv.setFillColor(MID_GREY)
            canv.drawString(L_MARGIN, 10*mm,
                "Sources: FCA Handbook TC App 1.1 & TC App 4 | SYSC 5.1.5ABR | SYSC 27 | CFA UK TC App 4 Appendix")
            canv.drawRightString(w-R_MARGIN, 10*mm,
                f"As at {date.today().strftime('%B %Y')} | Professional reference only — not legal advice")
        canv.restoreState()

