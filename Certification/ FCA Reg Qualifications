        title="FCA Regulatory Qualification Requirements — IMC L4 + CFA L1 Compliance Status",
        author="Compliance Reference",
    )
    on_page = DocCanvas()
    story = []

    # ── COVER ────────────────────────────────────────────────────────────────
    story.append(Spacer(1, 52*mm))
    story.append(Paragraph("FCA Regulatory<br/>Qualification<br/>Requirements", S("cover_title")))
    story.append(Spacer(1, 3*mm))
    story.append(Paragraph(
        "By Finance Role — with IMC Level 4 + CFA Level I<br/>Compliance Status Indicators",
        S("cover_sub")))
