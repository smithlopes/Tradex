        "Role-by-role mapping drawn from FCA Handbook TC App 1.1 (regulated activities),<br/>"
        "TC App 4 (appropriate qualifications tables), SYSC 5.1.5ABR (MiFID II knowledge<br/>"
        "and competence), and SYSC 27 (SM&amp;CR Certification Regime).",
        S("cover_meta")))
    story.append(Spacer(1, 6*mm))

    # Summary box on cover
    n_yes = status_counts["yes"]; n_part = status_counts["partial"]
    n_no = status_counts["no"];   n_disc = status_counts["discretion"]
    total = len(ROWS_DATA)
    summary_data = [[
        Paragraph(f"<b>{n_yes}</b><br/><font size='7'>Fully qualified</font>",
            ParagraphStyle("cs", fontName="Helvetica-Bold", fontSize=18, leading=22,
                           textColor=colors.HexColor("#5FD48A"), alignment=TA_LEFT)),
        Paragraph(f"<b>{n_part}</b><br/><font size='7'>Partial coverage</font>",
            ParagraphStyle("cs", fontName="Helvetica-Bold", fontSize=18, leading=22,
