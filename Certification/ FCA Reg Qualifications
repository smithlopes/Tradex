        "note_sm":      dict(fontName="Helvetica-Oblique", fontSize=6.5, leading=9.5, textColor=MID_GREY),
        "footnote":     dict(fontName="Helvetica", fontSize=6.5, leading=9.5, textColor=MID_GREY),
        "h1":           dict(fontName="Helvetica-Bold", fontSize=13, leading=17, textColor=NAVY, spaceBefore=14, spaceAfter=4),
        "intro":        dict(fontName="Helvetica", fontSize=8.5, leading=13, textColor=BODY_GREY, alignment=TA_JUSTIFY, spaceAfter=6),
        "key_abbr":     dict(fontName="Helvetica-Bold", fontSize=7.5, leading=10, textColor=NAVY),
